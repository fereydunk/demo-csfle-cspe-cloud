{
  "type": "object",
  "title": "MortgageApplication",
  "properties": {
    "loan_id":             { "type": "string" },
    "applicant_name":      { "type": "string" },
    "ssn":                 { "type": "string", "confluent:tags": ["PII"] },
    "credit_card_number":  { "type": "string", "confluent:tags": ["PCI"] },
    "card_cvv":            { "type": "string", "confluent:tags": ["PCI"] },
    "annual_income_usd":   { "type": "number" },
    "loan_amount_usd":     { "type": "number" },
    "credit_score":        { "type": "integer" },
    "property_address":    { "type": "string" },
    "loan_purpose":        { "type": "string", "enum": ["PURCHASE", "REFINANCE", "CASH_OUT"] }
  },
  "required": ["loan_id", "applicant_name", "ssn", "annual_income_usd", "loan_amount_usd", "credit_score", "property_address", "loan_purpose"]
}
