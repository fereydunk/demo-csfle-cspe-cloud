# demo-csfle-cspe-cloud — environment configuration
#
# Copy this file to `.env` (gitignored) and the wizard will populate the empty
# fields as you walk through the setup steps. AWS credentials live separately
# in `config/aws-session.env` so they can rotate independently.

# ── Confluent Cloud (filled by wizard step 1) ────────────────────────────────
ENV_ID=
ENV_NAME=
CLUSTER_ID=
CLUSTER_NAME=
BOOTSTRAP_SERVERS=
KAFKA_API_KEY=
KAFKA_API_SECRET=

SR_ID=
SR_URL=
SR_API_KEY=
SR_API_SECRET=

# ── KEKs (filled by wizard step 2 — created programmatically in AWS KMS) ─────
# AWS region for both KEKs. The wizard creates ENCRYPT_DECRYPT keys here and
# registers them in the SR DEK Registry under the aliases below.
AWS_REGION=us-west-2

CSFLE_KEK_NAME=mortgage-csfle-kek
CSFLE_KMS_ARN=
CSPE_KEK_NAME=mortgage-cspe-kek
CSPE_KMS_ARN=

# ── Topics (filled by wizard step 3) ─────────────────────────────────────────
CSFLE_TOPIC=mortgage-csfle
CSPE_TOPIC=mortgage-cspe

# ── Encryption authorization ─────────────────────────────────────────────────
# Cloud CSFLE/CSPE require Stream Governance ADVANCED on the env. No client-
# side license JWT is needed (unlike on-prem CP, which requires
# confluent.value.encryption.license=<JWT>). Verify in Cloud UI:
#   Environment → Stream Governance → must show "Advanced" tier.
# If on Essentials, upgrade before running scripts/02_register_schemas.sh —
# rule registration will fail with "feature requires Advanced" otherwise.

# ── Per-(topic,role) service accounts (filled by setup card 4 step 3 — RBAC) ─
# The wizard mints SIX SAs (one per consumer/producer page) so each principal
# has ONLY the KEK access its specific page needs. Per the principle of least
# privilege, the CSFLE-with-KEK consumer SA has DeveloperRead on the CSFLE
# KEK only — NOT the CSPE KEK — and vice versa. The no-KEK SAs have no Kek
# binding at all, so their DEK Registry lookups return 403 (the demonstrable
# Confluent-side enforcement of the no-KEK boundary).
# Cleanup: `make clean-rbac` deletes all 6 SAs (cascades to API keys + bindings).

# CSFLE producer (DeveloperWrite on Topic:csfle + Subject:csfle-value + Kek:csfle-kek)
CSFLE_PRODUCER_SA_ID=
CSFLE_PRODUCER_KAFKA_API_KEY=
CSFLE_PRODUCER_KAFKA_API_SECRET=
CSFLE_PRODUCER_SR_API_KEY=
CSFLE_PRODUCER_SR_API_SECRET=

# CSPE producer (DeveloperWrite on Topic:cspe + Subject:cspe-value + Kek:cspe-kek)
CSPE_PRODUCER_SA_ID=
CSPE_PRODUCER_KAFKA_API_KEY=
CSPE_PRODUCER_KAFKA_API_SECRET=
CSPE_PRODUCER_SR_API_KEY=
CSPE_PRODUCER_SR_API_SECRET=

# CSFLE consumer with KEK access (DeveloperRead on Kek:csfle-kek only)
CSFLE_CONSUMER_KEK_SA_ID=
CSFLE_CONSUMER_KEK_KAFKA_API_KEY=
CSFLE_CONSUMER_KEK_KAFKA_API_SECRET=
CSFLE_CONSUMER_KEK_SR_API_KEY=
CSFLE_CONSUMER_KEK_SR_API_SECRET=

# CSFLE consumer without KEK access (NO Kek binding — gets 403 on DEK lookup)
CSFLE_CONSUMER_NOKEK_SA_ID=
CSFLE_CONSUMER_NOKEK_KAFKA_API_KEY=
CSFLE_CONSUMER_NOKEK_KAFKA_API_SECRET=
CSFLE_CONSUMER_NOKEK_SR_API_KEY=
CSFLE_CONSUMER_NOKEK_SR_API_SECRET=

# CSPE consumer with KEK access (DeveloperRead on Kek:cspe-kek only)
CSPE_CONSUMER_KEK_SA_ID=
CSPE_CONSUMER_KEK_KAFKA_API_KEY=
CSPE_CONSUMER_KEK_KAFKA_API_SECRET=
CSPE_CONSUMER_KEK_SR_API_KEY=
CSPE_CONSUMER_KEK_SR_API_SECRET=

# CSPE consumer without KEK access (NO Kek binding — gets 403 on DEK lookup)
CSPE_CONSUMER_NOKEK_SA_ID=
CSPE_CONSUMER_NOKEK_KAFKA_API_KEY=
CSPE_CONSUMER_NOKEK_KAFKA_API_SECRET=
CSPE_CONSUMER_NOKEK_SR_API_KEY=
CSPE_CONSUMER_NOKEK_SR_API_SECRET=

# ── CSFLE2 — multi-rule add-on (PII + PCI on the same schema, two KEKs) ──────
# Optional. Filled by wizard "Run all" (final step) or `bash scripts/04_setup_csfle2.sh`.
# Demonstrates Confluent Cloud's multi-rule-per-schema feature (Limited
# Availability — may need account-team enablement). Uses validateRules=false
# at the SR /config endpoint to unlock multi-rule. Each rule is billed
# separately, so CSFLE2 = 2 rules = 2x encryption cost.
# Cleanup: `make clean-csfle2-rbac` + `make clean-csfle2-keys`.

CSFLE2_TOPIC=mortgage-csfle2

# Two KEKs — one per tag scope. Same AWS_REGION as CSFLE/CSPE.
CSFLE2_PII_KEK_NAME=mortgage-csfle2-pii-kek
CSFLE2_PII_KMS_ARN=
CSFLE2_PCI_KEK_NAME=mortgage-csfle2-pci-kek
CSFLE2_PCI_KMS_ARN=

# CSFLE2 producer (DevWrite on Topic + Subject + BOTH KEKs)
CSFLE2_PRODUCER_SA_ID=
CSFLE2_PRODUCER_KAFKA_API_KEY=
CSFLE2_PRODUCER_KAFKA_API_SECRET=
CSFLE2_PRODUCER_SR_API_KEY=
CSFLE2_PRODUCER_SR_API_SECRET=

# CSFLE2 consumer w/ PII KEK only (decrypts ssn; cc/cvv stay ciphertext)
CSFLE2_CONSUMER_PII_SA_ID=
CSFLE2_CONSUMER_PII_KAFKA_API_KEY=
CSFLE2_CONSUMER_PII_KAFKA_API_SECRET=
CSFLE2_CONSUMER_PII_SR_API_KEY=
CSFLE2_CONSUMER_PII_SR_API_SECRET=

# CSFLE2 consumer w/ PCI KEK only (decrypts cc/cvv; ssn stays ciphertext)
CSFLE2_CONSUMER_PCI_SA_ID=
CSFLE2_CONSUMER_PCI_KAFKA_API_KEY=
CSFLE2_CONSUMER_PCI_KAFKA_API_SECRET=
CSFLE2_CONSUMER_PCI_SR_API_KEY=
CSFLE2_CONSUMER_PCI_SR_API_SECRET=

# CSFLE2 consumer w/ both KEKs (everything decrypts)
CSFLE2_CONSUMER_BOTH_SA_ID=
CSFLE2_CONSUMER_BOTH_KAFKA_API_KEY=
CSFLE2_CONSUMER_BOTH_KAFKA_API_SECRET=
CSFLE2_CONSUMER_BOTH_SR_API_KEY=
CSFLE2_CONSUMER_BOTH_SR_API_SECRET=

# CSFLE2 consumer w/ no KEKs (DEK Registry returns 403 on every tagged field)
CSFLE2_CONSUMER_NONE_SA_ID=
CSFLE2_CONSUMER_NONE_KAFKA_API_KEY=
CSFLE2_CONSUMER_NONE_KAFKA_API_SECRET=
CSFLE2_CONSUMER_NONE_SR_API_KEY=
CSFLE2_CONSUMER_NONE_SR_API_SECRET=
